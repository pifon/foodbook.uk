#!/usr/bin/env sh
# Usage: ./up foodbook           → local (ports 8081/8444, self-signed cert)
#        ./up foodbook.uk        → production (ports 80/443; LETSENCRYPT_EMAIL for Let's Encrypt)
#        ./up foodbook --wipe    → wipe containers, volumes, networks, and image for this project, then start from 0
# Copies the right .env preset to .env, then compose up foodbook --build -d (optionally after a full wipe).

set -e

PRESET_NAME=
case "$1" in
  foodbook|foodbook.uk)
    PRESET_NAME="$1"
    ;;
  *)
    echo "Usage: $0 foodbook|foodbook.uk [--wipe]"
    echo "  foodbook    – local (FOODBOOK_BIND=127.0.0.1, ports 8081/8444)"
    echo "  foodbook.uk – production (ports 80/443; set LETSENCRYPT_EMAIL for Let's Encrypt, else self-signed)"
    echo "  --wipe      – remove all containers, volumes, networks, and the built image for this project, then start fresh"
    exit 1
    ;;
esac

WIPE=
PROXY=
shift
for arg in "$@"; do
  case "$arg" in
    --wipe) WIPE=1 ;;
    --proxy) PROXY=1 ;;
    *) ;;
  esac
done

PRESET=".env.$PRESET_NAME"
if [ ! -f "$PRESET" ]; then
  echo "Missing $PRESET"
  exit 1
fi

# Preserve existing APP_KEY if preset has it empty (avoid 500 after key:generate)
SAVED_APP_KEY=
if [ -f .env ] && grep -qE '^APP_KEY=base64:' .env 2>/dev/null; then
  SAVED_APP_KEY=$(grep -E '^APP_KEY=' .env | head -1)
fi
cp "$PRESET" .env
if [ -n "$SAVED_APP_KEY" ] && grep -qE '^APP_KEY=\s*$' .env 2>/dev/null; then
  grep -v '^APP_KEY=' .env > .env.tmp && echo "$SAVED_APP_KEY" >> .env.tmp && mv .env.tmp .env
fi

if [ -n "$PROXY" ]; then
  # Behind reverse proxy: don't bind host 80/443 and don't run certbot standalone.
  sed -i \
    -e 's|^LETSENCRYPT_EMAIL=.*|LETSENCRYPT_EMAIL=|' \
    -e 's|^FOODBOOK_BIND=.*|FOODBOOK_BIND=127.0.0.1|' \
    -e 's|^FOODBOOK_HTTP_PORT=.*|FOODBOOK_HTTP_PORT=8081|' \
    -e 's|^FOODBOOK_HTTPS_PORT=.*|FOODBOOK_HTTPS_PORT=8444|' \
    .env 2>/dev/null || true
  # Ensure keys exist even if missing in preset
  grep -q '^FOODBOOK_BIND=' .env || printf '\nFOODBOOK_BIND=127.0.0.1\n' >> .env
  grep -q '^FOODBOOK_HTTP_PORT=' .env || printf 'FOODBOOK_HTTP_PORT=8081\n' >> .env
  grep -q '^FOODBOOK_HTTPS_PORT=' .env || printf 'FOODBOOK_HTTPS_PORT=8444\n' >> .env
  grep -q '^LETSENCRYPT_EMAIL=' .env || printf 'LETSENCRYPT_EMAIL=\n' >> .env
  echo "Using $PRESET → .env (proxy mode: host ports 8081/8444; certbot disabled)"
else
  echo "Using $PRESET → .env"
fi

if [ -n "$WIPE" ]; then
  echo "Wiping project: containers, volumes, networks, and image..."
  docker compose down -v --rmi local --remove-orphans 2>/dev/null || true
  echo "Wipe done. Starting from 0."
fi

# Tear down any existing container so host ports are free (avoids "port already in use" on first run).
docker compose down 2>/dev/null || true

# If a stale container exists outside this compose project, remove it (avoids "container name already in use").
docker rm -f foodbook 2>/dev/null || true
docker compose up foodbook --build -d

# If APP_KEY is empty, Laravel will 500. Generate and restart so the app has a key.
if grep -qE '^APP_KEY=\s*$' .env 2>/dev/null; then
  echo "APP_KEY was empty; generating key and restarting foodbook..."
  sleep 3
  docker exec foodbook php artisan key:generate --force
  docker restart foodbook
fi
