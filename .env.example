APP_NAME=Foodbook
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Naming: API = external backend (API_BASE_URL). api = internal Foodbook proxy (/api/*).

# Must match the URL you use in the browser. Live: APP_URL=https://foodbook.uk (no other config change).
# Local with reverse-proxy: APP_URL=https://foodbook; set FOODBOOK_BIND=127.0.0.1, FOODBOOK_HTTP_PORT=8081, FOODBOOK_HTTPS_PORT=8444 (API uses 8080/8443).
APP_URL=https://foodbook
# Production (same image, just change URL): APP_URL=https://foodbook.uk

SESSION_DRIVER=file
SESSION_LIFETIME=120
# If you get "CSRF token mismatch" when submitting forms (e.g. register), try:
# - Use the same URL in the browser as APP_URL (e.g. https://foodbook when using the reverse-proxy)
# - Or set SESSION_SECURE_COOKIE=false when using HTTP or self-signed HTTPS
# SESSION_SECURE_COOKIE=

# API (external): base URL for all outbound requests (auth, recipes, cuisines, etc.).
API_BASE_URL=https://pifon/api

# When outbound requests to the API loop back to Foodbook (e.g. in Docker), api proxy forwards to the API at this URL.
# Example: https://172.18.0.3/api (API container IP on api_laravel-network)
# API_INTERNAL_BASE_URL=

API_VERIFY_SSL=true

# Optional: Docker port mapping when using reverse-proxy (proxy keeps 80/443). Leave unset for live (foodbook.uk).
# FOODBOOK_BIND=127.0.0.1
# FOODBOOK_HTTP_PORT=8081
# FOODBOOK_HTTPS_PORT=8444
