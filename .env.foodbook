# Local / dev: use with ./up foodbook (reverse-proxy on host keeps 80/443; container uses 8081/8444)
# Set APP_KEY (e.g. copy from existing .env or run: php artisan key:generate --show).
APP_NAME=Foodbook
APP_ENV=local
APP_KEY=
APP_DEBUG=true

APP_URL=https://foodbook

SESSION_DRIVER=file
SESSION_LIFETIME=120

API_BASE_URL=https://pifon/api
API_INTERNAL_BASE_URL=https://172.18.0.3/api
API_VERIFY_SSL=true

FOODBOOK_BIND=127.0.0.1
FOODBOOK_HTTP_PORT=8081
FOODBOOK_HTTPS_PORT=8444
